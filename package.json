{
  "name": "carelwave-media",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Carelwave Media - Professional Portfolio & Blog Platform with Advanced Features",
  "author": "Carelwave Media Development Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "analyze": "npx vite-bundle-analyzer",
    "server": "cd src/server && npm start",
    "server:dev": "cd src/server && npm run dev",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md}\"",
    "pre-commit": "npm run lint && npm run typecheck && npm run format:check",
    "deploy": "npm run build && npm run deploy:static",
    "deploy:static": "gh-pages -d dist"
  },
  "dependencies": {
    "@google-analytics/data": "^4.12.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "firebase": "^10.7.1",
    "framer-motion": "^10.16.16",
    "google-auth-library": "^9.15.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "sonner": "^1.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/crypto-js": "^4.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.0.8",
    "vite-bundle-analyzer": "^0.7.0",
    "vite-plugin-pwa": "^0.17.5",
    "workbox-window": "^7.3.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "24.x",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "portfolio",
    "blog",
    "react",
    "typescript",
    "pwa",
    "analytics",
    "security",
    "performance",
    "voice-commands",
    "email-marketing"
  ],
  "homepage": "https://carelwavemedia.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/carelwave/carelwave-media.git"
  },
  "bugs": {
    "url": "https://github.com/carelwave/carelwave-media/issues"
  }
}
