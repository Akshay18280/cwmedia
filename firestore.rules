rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - allow authenticated users to manage their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || 
         resource == null || 
         resource.data == null);
      
      // Allow creation during phone auth signup
      allow create: if request.auth != null;
    }
    
    // Posts collection - public read, admin write
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.token.admin == true || 
         request.auth.uid in resource.data.authorizedUsers);
      allow create: if request.auth != null;
    }
    
    // Newsletter collection - allow subscriptions and unsubscriptions
    match /newsletters/{newsletterId} {
      allow read: if true; // Allow reading for stats
      allow create: if true; // Allow newsletter subscriptions
      allow update: if true; // Allow status updates (unsubscribe)
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Admin verification collection - for OTP storage
    match /admin_verification/{phoneNumber} {
      allow read, write: if true; // Allow OTP operations
      allow create: if true; // Allow OTP creation
      allow update: if true; // Allow OTP verification
    }
    
    // Reviews collection - public read, authenticated write with approval
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
        (request.auth.token.admin == true || request.auth.uid == resource.data.userId);
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Comments collection - authenticated users can manage their comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
    }
    
    // Analytics collection - admin only
    match /analytics/{docId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Allow all other collections for authenticated users (fallback)
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
} 