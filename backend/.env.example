# Required
OPENAI_API_KEY=sk-your-openai-api-key

# Optional — set to "anthropic" and provide key to use Claude instead
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# Database (defaults match docker-compose)
DATABASE_URL=postgres://raguser:ragpass@postgres:5432/ragdb?sslmode=disable

# Embedding
EMBEDDING_MODEL=text-embedding-3-small

# RAG parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MIN=10
MAX_UPLOAD_SIZE_MB=20
