# Firebase Config (Required)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Security (Required for production)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# Email Service (Optional)
VITE_RESEND_API_KEY=re_xxxxxxxxxxxx

# Analytics (Optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GITHUB_USERNAME=your-github-username
VITE_ENABLE_ANALYTICS=true

# Video Services (Optional)
VITE_YOUTUBE_API_KEY=your-youtube-api-key
VITE_YOUTUBE_CLIENT_ID=your-youtube-client-id
VITE_VIMEO_CLIENT_ID=your-vimeo-client-id
VITE_VIMEO_ACCESS_TOKEN=your-vimeo-token

# AI Services (Optional)
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxx
VITE_OPENAI_ORG_ID=org-xxxxxxxxxxxx

# WebSocket (Optional - defaults to window.location.host)
VITE_WS_HOST=localhost
VITE_WS_PORT=3001

# Push Notifications (Optional)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_VOICE_COMMANDS=false
VITE_DEBUG_MODE=false

# IP Authentication (Deprecated - Use Firebase Custom Claims instead)
VITE_IP_AUTH_ENABLED=false
VITE_ADMIN_ALLOWED_IPS=
