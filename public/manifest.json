      "icons": [
        {
          "src": "/icons/blog-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "About Akshay",
      "short_name": "About",
      "description": "Learn about Akshay Verma's expertise and experience",
