# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# IP-Based Authentication Configuration
# Enable or disable IP-based authentication
VITE_IP_AUTH_ENABLED=true

# Comma-separated list of allowed IP addresses for admin access
# Supports exact IPs and CIDR notation
VITE_ADMIN_ALLOWED_IPS=192.168.0.100

# Admin password for automatic Firebase authentication
# CRITICAL: This must match your admin account password in Firebase
# Required for Firestore security rules to recognize IP-authenticated users
VITE_ADMIN_AUTO_PASSWORD=your-secure-admin-password

# Examples of IP configurations:
# Single IP: 192.168.0.100 (current configuration)
# Multiple IPs: 192.168.0.100,203.0.113.45
# CIDR Range: 192.168.1.0/24 (allows 192.168.1.1 to 192.168.1.254)
# Mixed: 127.0.0.1,192.168.1.0/24,203.0.113.45
# Note: Currently configured for only 192.168.0.100

# Other Configuration
VITE_APP_TITLE=Carelwave Media
VITE_APP_DESCRIPTION=Modern content management platform 